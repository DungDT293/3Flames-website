generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique @db.VarChar(255)
  username     String   @unique @db.VarChar(100)
  phone        String?  @unique @db.VarChar(20)
  passwordHash String   @map("password_hash") @db.VarChar(255)

  // CRITICAL: balance uses Decimal(16,6) for financial precision.
  // All mutations MUST go through SELECT ... FOR UPDATE to prevent race conditions.
  balance      Decimal  @default(0) @db.Decimal(16, 6)

  role         UserRole @default(USER)
  status       UserStatus @default(ACTIVE)

  // Terms of Service version the user accepted at registration (or last update)
  acceptedTosVersion String @default("1.0") @map("accepted_tos_version") @db.VarChar(20)
  isEmailVerified  Boolean   @default(false) @map("is_email_verified")
  otpCode          String?   @map("otp_code") @db.VarChar(6)
  otpExpiresAt     DateTime? @map("otp_expires_at")

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")

  orders       Order[]
  transactions Transaction[]
  depositRequests DepositRequest[]
  auditLogsAsActor AuditLog[] @relation("AuditActor")
  auditLogsAsTarget AuditLog[] @relation("AuditTarget")

  @@index([email])
  @@index([phone])
  @@index([status])
  @@map("users")
}

enum UserRole {
  USER
  SUPPORT
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  actorId   String?  @map("actor_id") @db.Uuid
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id])

  targetId  String?  @map("target_id") @db.Uuid
  target    User?    @relation("AuditTarget", fields: [targetId], references: [id])

  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)

  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")

  ipAddress String?  @map("ip_address") @db.VarChar(45)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([targetId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([targetId, createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// SERVICES
// ─────────────────────────────────────────────────────────────
model Service {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Provider's service ID — used when placing orders upstream
  providerServiceId  String    @unique @map("provider_service_id") @db.VarChar(50)

  name           String        @db.VarChar(500)
  category       String        @db.VarChar(255)
  description    String?       @db.Text

  // Provider's cost per 1000 units
  originalPrice  Decimal       @map("original_price") @db.Decimal(16, 6)

  // Our retail price = originalPrice * (1 + profitMargin/100)
  sellingPrice   Decimal       @map("selling_price") @db.Decimal(16, 6)

  // The margin applied when this price was last calculated
  profitMargin   Decimal       @default(30) @map("profit_margin") @db.Decimal(5, 2)
  isMarginOverride Boolean     @default(false) @map("is_margin_override")

  minQuantity    Int           @map("min_quantity")
  maxQuantity    Int           @map("max_quantity")

  type           ServiceType   @default(DEFAULT)
  isActive       Boolean       @default(true) @map("is_active")

  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  orders         Order[]

  @@index([category])
  @@index([isActive])
  @@index([providerServiceId])
  @@map("services")
}

enum ServiceType {
  DEFAULT
  SUBSCRIPTION
  CUSTOM_COMMENTS
  PACKAGE
}

model AdminSetting {
  key       String   @id @db.VarChar(100)
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admin_settings")
}

// ─────────────────────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────────────────────
model Order {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId       String      @map("user_id") @db.Uuid
  user         User        @relation(fields: [userId], references: [id])

  serviceId    String      @map("service_id") @db.Uuid
  service      Service     @relation(fields: [serviceId], references: [id])

  // Provider's order ID — returned after placeOrder call
  apiOrderId   String?     @map("api_order_id") @db.VarChar(100)

  // The target link/URL for the service
  link         String      @db.VarChar(2000)
  quantity     Int

  // Exact amount deducted from user balance at order time
  charge       Decimal     @db.Decimal(16, 6)
  cost         Decimal     @default(0) @db.Decimal(16, 6)

  status       OrderStatus @default(PENDING)

  // Provider-reported start count & remaining count (for partial refund calc)
  startCount   Int?        @map("start_count")
  remains      Int?

  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([apiOrderId])
  @@index([createdAt])
  @@index([userId, status])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PROCESSING
  IN_PROGRESS
  COMPLETED
  PARTIAL
  CANCELED
  REFUNDED
  ERROR
}

// ─────────────────────────────────────────────────────────────
// TRANSACTIONS (Strict Financial Ledger)
// ─────────────────────────────────────────────────────────────
model Transaction {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId       String          @map("user_id") @db.Uuid
  user         User            @relation(fields: [userId], references: [id])

  type         TransactionType
  amount       Decimal         @db.Decimal(16, 6)

  // Balance AFTER this transaction was applied — audit trail
  balanceAfter Decimal         @map("balance_after") @db.Decimal(16, 6)

  // Optional reference to the order that triggered this transaction
  orderId      String?         @map("order_id") @db.Uuid

  description  String          @db.VarChar(500)

  createdAt    DateTime        @default(now()) @map("created_at")

  @@index([userId])
  @@index([type])
  @@index([orderId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("transactions")
}

enum TransactionType {
  DEPOSIT
  PURCHASE
  REFUND
  ADMIN_CREDIT
  ADMIN_DEBIT
}

// ─────────────────────────────────────────────────────────────
// DEPOSIT REQUESTS (VietQR Payment Intent)
// Tracks pending deposits before they are confirmed via webhook.
// The memo field is the reconciliation key between QR and webhook.
// ─────────────────────────────────────────────────────────────
model DepositRequest {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId       String              @map("user_id") @db.Uuid
  user         User                @relation(fields: [userId], references: [id])

  memo         String              @unique @db.VarChar(50)
  amountVnd    Int                 @map("amount_vnd")
  status       DepositStatus       @default(PENDING)

  providerPaymentId String?        @unique @map("provider_payment_id") @db.VarChar(200)
  transactionId     String?        @map("transaction_id") @db.Uuid

  expiresAt    DateTime            @map("expires_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  @@index([userId])
  @@index([memo])
  @@index([status])
  @@index([providerPaymentId])
  @@map("deposit_requests")
}

enum DepositStatus {
  PENDING
  CONFIRMED
  EXPIRED
  FAILED
}
