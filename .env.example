# Environment
NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL="postgresql://flames_user:flames_password@localhost:5432/flames_db?schema=public"

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Provider API (TheYTlab)
PROVIDER_API_URL=https://theytlab.com/api/v2
PROVIDER_API_KEY=your-provider-api-key

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=3flames-assets
R2_PUBLIC_URL=https://assets.3flames.com

# Profit Margin (percentage added on top of provider price)
DEFAULT_PROFIT_MARGIN=30

# Webhook (Payment Gateway HMAC signature verification)
WEBHOOK_SECRET=your-webhook-hmac-secret-change-in-production

# Circuit Breaker (Provider downtime protection)
CB_FAILURE_THRESHOLD=5
CB_FAILURE_WINDOW_MS=120000
CB_COOLDOWN_MS=1800000

# Terms of Service version (bump when ToS changes to force re-acceptance)
CURRENT_TOS_VERSION=1.0
